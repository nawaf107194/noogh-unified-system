# ═══════════════════════════════════════════════════════════════
# NOOGH Evolution Engine — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# All variables use prefix NOOGH_EVO_
# Copy to .env and adjust as needed.

# ── Risk & Approval ──
# NOOGH_EVO_AUTO_EXECUTE_RISK=75
# NOOGH_EVO_AGENT_RISK=90
# NOOGH_EVO_LOW_RISK=30

# ── Rate Limits ──
# NOOGH_EVO_MAX_PROPOSALS_HOUR=20
# NOOGH_EVO_MAX_EXECUTIONS_HOUR=10
# NOOGH_EVO_MAX_TOTAL=1000

# ── Ledger ──
# NOOGH_EVO_RISK_THRESHOLD=60
# NOOGH_EVO_FAILURE_COOLDOWN=300

# ── Per-Type Risk ──
# NOOGH_EVO_CONFIG_RISK=75
# NOOGH_EVO_POLICY_RISK=65
# NOOGH_EVO_CODE_RISK=75
# NOOGH_EVO_SANDBOX_TIMEOUT=10.0

# ── Brain Refactoring ──
# NOOGH_EVO_REFACTOR_COOLDOWN=3600
# NOOGH_EVO_BRAIN_MAX_TOKENS=2048
# NOOGH_EVO_BRAIN_TIMEOUT=120
# NOOGH_EVO_BRAIN_MAX_CONCURRENT=2
# NOOGH_EVO_BRAIN_MAX_ISSUES=2
# NOOGH_EVO_MAX_EXTRACTION_RETRIES=2
# NOOGH_EVO_MAX_DIFF_SIZE=50000
# NOOGH_EVO_MAX_FUNCTION_LINES=200

# ── Project ──
# NOOGH_EVO_PROJECT_ROOT=/home/noogh/projects/noogh_unified_system/src

# ── Deduplication ──
# NOOGH_EVO_DEDUP_WINDOW=900

# ── Kill Switch ──
# NOOGH_EVO_KILL_FAILURES=15
# NOOGH_EVO_KILL_COOLDOWN=86400

# ── Core Interface Lock ──
# NOOGH_EVO_CORE_LOCKED_FILES=orchestrator.py,module_interface.py,governor.py,...

# ── Canary Phases ──
# NOOGH_EVO_CANARY_IMPORT_TEST=true
# NOOGH_EVO_CANARY_EMISSION_GUARD=true
# NOOGH_EVO_CANARY_CORE_LOCK=true

# ── Distillation ──
# NOOGH_EVO_DISTILL_MIN_QUALITY=0.6
# NOOGH_EVO_DISTILL_MAX_TRAJ=5000

# ── Circuit Breaker ──
# NOOGH_EVO_CB_FAILURES=5
# NOOGH_EVO_CB_RECOVERY=60

# ── Neural Bridge ──
# NOOGH_EVO_NEURAL_MAX_RETRIES=3
# NOOGH_EVO_VLLM_TEMPERATURE=0.7
# NOOGH_EVO_NEURAL_CACHE_TTL=60

# ── Sensitive (not prefixed) ──
# NEURAL_ENGINE_URL=http://127.0.0.1:8002
# NEURAL_ENGINE_MODE=local
# NOOGH_INTERNAL_TOKEN=your-secret-token
# VLLM_MODEL_NAME=noogh-teacher
