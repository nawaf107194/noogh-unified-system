"""
Evolution Controller — Cognitive Orchestrator
Version: 3.0.0
Part of: Cognitive Evolution System

Orchestrates evolution through the full cognitive architecture:
- Triggers from events (not timers)
- ConsequenceEngine for permanent commits
- ScarTissue for pain-aware safety
- EvolutionMemory for learning
- EvolutionDreamer for creative discovery

v3.0: Connected to WorldModel, ConsequenceEngine, ScarTissue, CognitiveJournal
v2.0: Fixed crash bug, enabled CODE execution, added DB persistence.
"""

import asyncio
import logging
import time
import os
from typing import Dict, Any, List, Optional
from pathlib import Path

from .ledger import (
    EvolutionLedger, 
    EvolutionProposal, 
    ProposalStatus, 
    ProposalType,
    get_evolution_ledger
)
from .policy_gate import PolicyGate, get_policy_gate
from .sandbox import SandboxExecutor, get_sandbox_executor
from .proposer import PatchProposer
from .goal_audit import GoalAuditEngine
from .evolution_memory import EvolutionMemory, ProposalOutcome, get_evolution_memory
from .evolution_dreamer import EvolutionDreamer, get_evolution_dreamer
from .evolution_triggers import TriggerEvent, TriggerType
from . import evolution_config as config
from . import code_validator
from . import code_applier
from .diff_parser import extract_metadata_from_diff
from .promoted_targets import get_promoted_targets
from .creative_agent import get_creative_agent

logger = logging.getLogger("unified_core.evolution.controller")


class EvolutionController:
    """
    Cognitive Evolution Orchestrator v3.0
    
    Flow (Trigger-Driven):
    1. Receive TriggerEvent from EvolutionTriggerSystem
    2. Consult EvolutionMemory for strategy selection
    3. Run EvolutionDreamer for creative ideas (optional)
    4. Generate targeted proposals
    5. Validate with PolicyGate + ScarTissue risk
    6. Run canary test in sandbox
    7. Apply with ConsequenceEngine recording
    8. Record outcome to EvolutionMemory (learning)
    
    Legacy Flow (still supported):
    - process_pending_proposals()
    - run_evolution_cycle()
    - run_intelligence_evolution()
    """
    
    def __init__(self):
        # Existing components
        self.ledger = get_evolution_ledger()
        self.policy_gate = get_policy_gate()
        self.sandbox = get_sandbox_executor()
        self.proposer = PatchProposer()
        self.goal_audit = GoalAuditEngine()
        self.project_analyzer = None
        
        # v3.0 Cognitive components
        self.memory = get_evolution_memory()
        self.dreamer = get_evolution_dreamer()
        self._consequence_engine = None  # Set via set_consequence_engine()
        self._scar_tissue = None         # Set via set_scar_tissue()
        self._world_model = None         # Set via set_world_model()
        self._journal = None             # Set via set_journal()
        
        # v3.4 Neuron Learning — connects evolution to NeuronFabric
        try:
            from .neuron_learning import get_neuron_learning_bridge
            self._neuron_bridge = get_neuron_learning_bridge()
        except Exception as e:
            logger.warning(f"NeuronLearningBridge not available: {e}")
            self._neuron_bridge = None
        
        # Processing stats
        self.proposals_processed = 0
        self.proposals_approved = 0
        self.proposals_rejected = 0
        self.proposals_executed = 0
        self.proposals_generated = 0
        self._triggers_handled = 0
        self._dreams_realized = 0
        
        # Auto-execution settings
        self.auto_execute_config = True
        self.auto_execute_policy = True
        self.auto_execute_code = True
        
        # v4.1: Persistent promoted targets memory
        self._promoted_targets = get_promoted_targets()
        
        # v5.0: Creative Evolution Agent (multi-strategy orchestrator)
        self._creative_agent = get_creative_agent()
        
        # v6.0: Cognitive Elite Orchestrator (Phase 1-3 Full Intelligence)
        try:
            from unified_core.intelligence.orchestrator import get_cognitive_orchestrator
            self._cognitive_engine = get_cognitive_orchestrator()
        except ImportError as e:
            logger.warning(f"CognitiveOrchestrator not available: {e}")
            self._cognitive_engine = None
        
        logger.info(f"🧬 EvolutionController v5.0 initialized (promoted={self._promoted_targets.count()})")
    
    # --- Cognitive Component Wiring ---
    
    def set_consequence_engine(self, engine):
        """Wire ConsequenceEngine for permanent action recording."""
        self._consequence_engine = engine
        logger.info("🧬 ConsequenceEngine connected to evolution")
    
    def set_scar_tissue(self, scars):
        """Wire ScarTissue for pain-aware risk adjustment."""
        self._scar_tissue = scars
        self._creative_agent.wire_components(failure_record=scars)
        logger.info("🧬 ScarTissue connected to evolution")
    
    def set_world_model(self, wm):
        """Wire WorldModel for belief-driven evolution."""
        self._world_model = wm
        self.dreamer.set_components(world_model=wm)
        self._creative_agent.wire_components(world_model=wm)
        logger.info("🧬 WorldModel connected to evolution")
    
    def set_journal(self, journal):
        """Wire CognitiveJournal for experience context."""
        self._journal = journal
        self.dreamer.set_components(journal=journal)
        logger.info("🧬 CognitiveJournal connected to evolution")
    
    def set_gravity_well(self, gw):
        """Wire GravityWell for goal-aligned evolution."""
        self.dreamer.set_components(gravity_well=gw)
        logger.info("🧬 GravityWell connected to evolution")
    
    def can_auto_execute(self, proposal: EvolutionProposal) -> bool:
        """Check if proposal can be auto-executed.
        
        v3.0: Thresholds raised to accommodate risk adjustments from
        ConsequenceEngine (+10-30) and ScarTissue (+5 per failure).
        The canary test provides the real safety gate, not this threshold.
        """
        if proposal.proposal_type == ProposalType.CONFIG:
            return self.auto_execute_config and proposal.risk_score <= config.CONFIG_RISK_THRESHOLD
        elif proposal.proposal_type == ProposalType.POLICY:
            return self.auto_execute_policy and proposal.risk_score <= config.POLICY_RISK_THRESHOLD
        elif proposal.proposal_type == ProposalType.CODE:
            return self.auto_execute_code and proposal.risk_score <= config.CODE_RISK_THRESHOLD
        elif proposal.proposal_type == ProposalType.AGENT:
            # Agents have dedicated AST validation in canary — allow higher risk
            return self.auto_execute_code and proposal.risk_score <= config.AGENT_RISK_THRESHOLD
        return False
    
    async def process_pending_proposals(self) -> Dict[str, Any]:
        """
        Process all pending proposals.
        
        v2.0: Deduplication — skips proposals targeting functions that are 
        already promoted, and prevents processing duplicate targets in 
        the same batch.
        
        Returns summary of processing results.
        """
        # Check safe mode
        if self.ledger.is_safe_mode():
            logger.warning("SAFE MODE: Skipping proposal processing")
            return {"status": "safe_mode", "processed": 0}
        
        # Get pending proposals
        pending = [
            p for p in self.ledger.proposals.values()
            if p.status == ProposalStatus.PENDING
        ]
        
        if not pending:
            return {"status": "no_pending", "processed": 0}
        
        # ── Deduplication Layer ──────────────────────────────────────
        # Build set of already-completed target+function combos
        # v4.1: Also check persistent promoted_targets (survives ledger reset)
        already_done = set()
        for p in self.ledger.proposals.values():
            if p.status in (ProposalStatus.PROMOTED, ProposalStatus.EXECUTED):
                target = p.targets[0] if p.targets else ''
                func = p.metadata.get('function', '') if p.metadata else ''
                if target and func:
                    already_done.add(f"{target}::{func}")
        
        # Add persistent promoted targets
        for key in self._promoted_targets.get_all():
            # Keys are "file:func" format, convert to "file::func" for compat
            parts = key.split(':', 1)
            if len(parts) == 2:
                already_done.add(f"{parts[0]}::{parts[1]}")
        
        # Filter and deduplicate pending proposals
        deduped_pending = []
        batch_seen = set()  # Prevent same target+func in this batch
        skipped = 0
        
        for proposal in pending:
            target = proposal.targets[0] if proposal.targets else ''
            func = proposal.metadata.get('function', '') if proposal.metadata else ''
            key = f"{target}::{func}" if target and func else proposal.proposal_id
            
            # Skip if already promoted/executed
            if key in already_done:
                logger.info(f"⏭️ Skipping duplicate: {func} in {target.split('/')[-1]} (already promoted)")
                proposal.status = ProposalStatus.REJECTED
                self.ledger.record_approval(proposal.proposal_id, False, "Duplicate: target already promoted")
                skipped += 1
                continue
            
            # Skip if duplicate in this batch (keep first only)
            if key in batch_seen:
                logger.info(f"⏭️ Skipping batch duplicate: {func} in {target.split('/')[-1]}")
                proposal.status = ProposalStatus.REJECTED
                self.ledger.record_approval(proposal.proposal_id, False, "Duplicate: same target in batch")
                skipped += 1
                continue
            
            batch_seen.add(key)
            deduped_pending.append(proposal)
        
        if skipped > 0:
            logger.info(f"🧹 Dedup: {skipped} duplicates skipped, {len(deduped_pending)} to process")
        # ─────────────────────────────────────────────────────────────
        
        results = []
        for proposal in deduped_pending:
            result = await self._process_proposal(proposal)
            results.append(result)
            self.proposals_processed += 1
        
        return {
            "status": "processed",
            "processed": len(results),
            "skipped_duplicates": skipped,
            "results": results
        }
    
    async def _process_proposal(self, proposal: EvolutionProposal, 
                               trigger_context: Dict[str, Any] = None) -> Dict[str, Any]:
        """Process a single proposal with cognitive awareness."""
        proposal_id = proposal.proposal_id
        
        # v3.5: Ensure proposal exists in the physical Ledger before proceeding
        if proposal_id not in self.ledger.proposals:
             self.ledger._load_ledger() # Sync with disk/DB
             if proposal_id not in self.ledger.proposals:
                 logger.error(f"❌ Critical Sync Error: {proposal_id} not found in Ledger")
                 return {"proposal_id": proposal_id, "status": "failed", "reason": "Proposal ID mismatch"}
                 
        logger.info(f"🔄 Processing proposal: {proposal_id}")
        
        # v3.0 Step 0: Check EvolutionMemory — should we skip this target?
        if proposal.targets and self.memory.should_skip_target(proposal.targets[0]):
            self.proposals_rejected += 1
            return {"proposal_id": proposal_id, "status": "skipped_fragile", 
                    "reason": "Target marked as fragile by EvolutionMemory"}
        
        # v3.0 Step 0.5: Adjust risk score with ScarTissue
        adjusted_risk = proposal.risk_score
        if self._scar_tissue and proposal.targets:
            scar_penalty = self.memory.get_scar_penalty(proposal.targets[0])
            if scar_penalty > 0:
                adjusted_risk = min(proposal.risk_score + scar_penalty, 95)
                logger.info(f"🩹 Scar penalty +{scar_penalty} → risk {proposal.risk_score}→{adjusted_risk}")
                proposal.risk_score = adjusted_risk
        
        # v3.0 Step 0.7: ConsequenceEngine — risk adjustment (not hard block)
        if self._consequence_engine:
            try:
                from ..core.consequence import Action
                action = Action(
                    action_type="evolution_change",
                    parameters={
                        "file": proposal.targets[0] if proposal.targets else "unknown",
                        "type": proposal.proposal_type.value if hasattr(proposal.proposal_type, 'value') else str(proposal.proposal_type)
                    }
                )
                constraints = self._consequence_engine.verify_constraints(action)
                if constraints:
                    # Add risk instead of blocking — let canary decide
                    constraint_penalty = min(len(constraints) * 10, 30)
                    old_risk = proposal.risk_score
                    proposal.risk_score = min(proposal.risk_score + constraint_penalty, 95)
                    logger.info(f"⚖️ ConsequenceEngine: {len(constraints)} past failures → risk +{constraint_penalty} ({old_risk}→{proposal.risk_score})")
            except Exception as e:
                logger.debug(f"ConsequenceEngine check skipped: {e}")
                
        # v6.0 Step 0.8: Cognitive Elite Validation
        if self._cognitive_engine and getattr(proposal, 'proposal_type', None) in (ProposalType.CODE, ProposalType.AGENT):
            try:
                # 1. Constraints Check
                feasibility = self._cognitive_engine.check_constraints(
                    action_name=f"Proposal_{proposal_id}",
                    attributes={
                        'max_risk_score': proposal.risk_score,
                        'min_confidence': 1.0 - (proposal.risk_score / 100.0)
                    }
                )
                if not feasibility['feasible'] and feasibility.get('hard_violations'):
                    msg = f"Cognitive Elite Block: Hard constraint violation: {feasibility['hard_violations'][0]['constraint']}"
                    logger.error(f"❌ {msg}")
                    self.ledger.record_approval(proposal_id, False, msg)
                    self.proposals_rejected += 1
                    return {"proposal_id": proposal_id, "status": "rejected_cognitive", "reason": msg}
                
                # 2. Critical Thinking on the proposal reasoning
                if hasattr(proposal, 'metadata') and proposal.metadata and proposal.metadata.get("analysis"):
                    eval_result = self._cognitive_engine.evaluate_evidence(
                        reasoning_chain=proposal.metadata.get("analysis", ""),
                        pieces=[{"claim": f"Proposal '{proposal.description}' justifies risk", "methodology_score": 0.5}]
                    )
                    if eval_result['overall_score'] < 0.5:
                        msg = f"Cognitive Elite Block: Reasoning score too low ({eval_result['overall_score']*100:.0f}%)"
                        logger.error(f"❌ {msg}")
                        self.ledger.record_approval(proposal_id, False, msg)
                        self.proposals_rejected += 1
                        return {"proposal_id": proposal_id, "status": "rejected_cognitive_reasoning", "reason": msg}
                
                # 3. Decision Explanation
                reasoning_str = proposal.metadata.get("analysis", "No deep analysis provided") if hasattr(proposal, 'metadata') and proposal.metadata else "No metadata"
                explanation = self._cognitive_engine.generate_explanation(
                    action=proposal.description,
                    reasoning=reasoning_str,
                    alternatives=[],
                    audience="technical"
                )
                logger.info(f"🧠 Cognitive Explanation Generated:\n{explanation}")
            except Exception as e:
                logger.debug(f"Cognitive Elite pipeline skipped for {proposal_id}: {e}")
        
        # Step 1: Validate with PolicyGate (original)
        valid, reason = self.policy_gate.validate(
            proposal.scope,
            proposal.targets,
            proposal.diff,
            proposal.risk_score
        )
        
        if not valid:
            self.ledger.record_approval(proposal_id, False, reason)
            self.proposals_rejected += 1
            return {"proposal_id": proposal_id, "status": "rejected", "reason": reason}
        
        # Step 2: Check if auto-execution is allowed
        if not self.can_auto_execute(proposal):
            self.ledger.record_approval(proposal_id, True, "Awaiting manual execution")
            self.proposals_approved += 1
            return {"proposal_id": proposal_id, "status": "approved_pending", "reason": "manual_required"}
        
        # Step 3: Approve and execute
        self.ledger.record_approval(proposal_id, True, "Auto-approved")
        self.proposals_approved += 1
        
        # Step 4: Run canary test
        canary_result = await self._run_canary(proposal)
        
        if not canary_result["success"]:
            self.ledger.record_canary_result(proposal_id, False, canary_result.get("error", ""))
            # v3.0: Record failure to memory
            self.memory.record_outcome(ProposalOutcome(
                proposal_id=proposal_id,
                proposal_type=str(proposal.proposal_type),
                target_area=proposal.targets[0] if proposal.targets else "unknown",
                trigger_type=trigger_context.get("trigger_type", "legacy") if trigger_context else "legacy",
                success=False,
                details={"phase": "canary", "error": canary_result.get("error", "")}
            ))
            
            # v3.4: Teach NeuronFabric from canary failure
            if self._neuron_bridge:
                self._neuron_bridge.learn_from_rejection(
                    proposal_id, proposal, "canary",
                    canary_result.get("error", "")
                )
            
            return {"proposal_id": proposal_id, "status": "canary_failed", "result": canary_result}
        
        self.ledger.record_canary_result(proposal_id, True, "Canary passed")
        
        # Step 5: Apply to production
        if proposal.proposal_type == ProposalType.CONFIG:
            apply_result = await self._apply_config_change(proposal)
        elif proposal.proposal_type == ProposalType.CODE:
            apply_result = await self._apply_code_change(proposal)
        elif proposal.proposal_type == ProposalType.AGENT:
            apply_result = await self._apply_agent_proposal(proposal)
        else:
            return {"proposal_id": proposal_id, "status": "approved", "result": canary_result}
        
        # v3.0: Record result to ConsequenceEngine and EvolutionMemory
        trigger_type = trigger_context.get("trigger_type", "legacy") if trigger_context else "legacy"
        
        if apply_result["success"]:
            self.ledger.record_promotion(proposal_id, True, apply_result.get("metrics"))
            self.proposals_executed += 1
            logger.warning(f"🚀 EVOLUTION APPLIED: {proposal_id} - {proposal.description}")
            
            # v4.1: Record to persistent promoted targets
            target_file = proposal.targets[0] if proposal.targets else ''
            target_func = proposal.metadata.get('function', '') if proposal.metadata else ''
            if target_file and target_func:
                self._promoted_targets.add(target_file, target_func, proposal_id)
            elif target_file and not target_func:
                # v13: Innovation or other proposals without function name — use description as key
                desc_key = proposal.description[:60].replace(' ', '_')
                self._promoted_targets.add(target_file, desc_key, proposal_id)
            # v9: Register agents in promoted_targets
            elif proposal.proposal_type == ProposalType.AGENT and target_file:
                agent_role = proposal.metadata.get('role', 'unknown') if proposal.metadata else 'unknown'
                self._promoted_targets.add(target_file, f"__agent__{agent_role}", proposal_id)
            
            # Record success to ConsequenceEngine
            await self._record_consequence(proposal, apply_result, success=True)
            
            # v9: Measure real impact_delta from metrics
            real_impact = apply_result.get("metrics", {}).get("impact_delta", 0.1)
            
            # Record success to EvolutionMemory
            self.memory.record_outcome(ProposalOutcome(
                proposal_id=proposal_id,
                proposal_type=str(proposal.proposal_type),
                target_area=proposal.targets[0] if proposal.targets else "unknown",
                trigger_type=trigger_type,
                success=True,
                impact_delta=real_impact,
                confidence=1 - (proposal.risk_score / 100),
                details=apply_result.get("metrics", {})
            ))
            
            # v3.4: Teach NeuronFabric from success
            if self._neuron_bridge:
                self._neuron_bridge.learn_from_promotion(proposal_id, proposal, apply_result)

            # v16: Record promotion to InstinctObserver for continuous learning
            try:
                from .instinct_system import get_instinct_advisor
                _meta = proposal.metadata or {}
                _itype = _meta.get("innovation_type", str(proposal.proposal_type))
                _title = proposal.description.replace("[INNOVATION] ", "")
                _lines = len(_meta.get("generated_code", "").splitlines())
                get_instinct_advisor().observer.record(
                    event_type="promoted",
                    proposal_id=proposal_id,
                    innovation_type=_itype,
                    title=_title,
                    target_file=proposal.targets[0] if proposal.targets else "",
                    lines_of_code=_lines,
                )
            except Exception:
                pass

            return {"proposal_id": proposal_id, "status": "applied", "result": apply_result}
        else:
            self.ledger.record_execution(
                proposal_id, False, 0, 
                error=apply_result.get("error", "Unknown error")
            )
            
            # Record failure to ConsequenceEngine
            await self._record_consequence(proposal, apply_result, success=False)
            
            # Record failure to EvolutionMemory
            self.memory.record_outcome(ProposalOutcome(
                proposal_id=proposal_id,
                proposal_type=str(proposal.proposal_type),
                target_area=proposal.targets[0] if proposal.targets else "unknown",
                trigger_type=trigger_type,
                success=False,
                impact_delta=-0.1,
                details={"error": apply_result.get("error", "")}
            ))
            
            # v3.4: Teach NeuronFabric from apply failure
            if self._neuron_bridge:
                self._neuron_bridge.learn_from_rejection(
                    proposal_id, proposal, "apply",
                    apply_result.get("error", "")
                )

            # v16: Record failure to InstinctObserver
            try:
                from .instinct_system import get_instinct_advisor
                _meta = proposal.metadata or {}
                _itype = _meta.get("innovation_type", str(proposal.proposal_type))
                _title = proposal.description.replace("[INNOVATION] ", "")
                get_instinct_advisor().observer.record(
                    event_type="failed",
                    proposal_id=proposal_id,
                    innovation_type=_itype,
                    title=_title,
                    target_file=proposal.targets[0] if proposal.targets else "",
                    error=apply_result.get("error", ""),
                )
            except Exception:
                pass

            return {"proposal_id": proposal_id, "status": "apply_failed", "result": apply_result}
    
    def _detect_indent(self, code: str) -> int:
        """Detect indentation level of the first def/async def line."""
        return code_applier.detect_indent(code)
    
    def _reindent(self, code: str, target_indent: int) -> str:
        """Re-indent code to match target indentation level."""
        return code_applier.reindent(code, target_indent)
    
    # ─── Core Interface Lock: prevent Brain from modifying critical files ──
    # Loaded from centralized config (v4.0)
    from .evolution_config import CORE_INTERFACE_LOCKED_FILES as CORE_INTERFACE_LOCK
    
    def _check_core_interface_lock(self, proposal: 'EvolutionProposal') -> Dict[str, Any]:
        """v4.0: Prevent Brain from modifying core system interfaces.
        
        These files form the structural skeleton of the system. Changes to them
        can destabilize the entire evolution pipeline. They require explicit
        architectural proposals with manual review.
        """
        if not proposal.targets:
            return {"pass": True, "reason": "No targets"}
        
        target = proposal.targets[0]
        target_basename = os.path.basename(target)
        
        # Check if target is a locked core interface
        if target_basename in self.CORE_INTERFACE_LOCK:
            # Allow if explicitly flagged for manual review
            if hasattr(proposal, 'metadata') and proposal.metadata:
                if proposal.metadata.get('requires_manual_review'):
                    return {"pass": True, "reason": f"Core interface {target_basename} — manual review flagged"}
            
            # Allow agent proposals (they create new files, not modify core)
            if proposal.proposal_type == ProposalType.AGENT:
                return {"pass": True, "reason": "Agent proposal — not modifying core"}
            
            return {
                "pass": False,
                "reason": f"CORE_LOCK: {target_basename} is a protected core interface. "
                          f"Requires architectural proposal with manual review."
            }
        
        return {"pass": True, "reason": "Not a core interface"}
    
    # ─── AST Emission Guard: validate code snippet BEFORE full-file merge ──
    def _ast_emission_guard(self, original_code: str, refactored_code: str,
                            metadata: Dict[str, Any]) -> Dict[str, Any]:
        """v4.0: AST-level validation — delegates to code_validator module."""
        return code_validator.ast_emission_guard(original_code, refactored_code, metadata)
    
    # ─── Policy Gate: reject dangerous refactor patterns ──────────────
    def _refactor_policy_check(self, refactored_code: str, target_file: str,
                                 metadata: Dict[str, Any]) -> Dict[str, Any]:
        """v3.3: Policy check — delegates to code_validator module."""
        return code_validator.refactor_policy_check(refactored_code, target_file, metadata)
    
    # ─── AST-based function finder ────────────────────────────────────
    def _find_function_in_file(self, file_content: str, func_name: str) -> Optional[str]:
        """v3.3: Find function by name — delegates to code_applier module."""
        return code_applier.find_function_in_file(file_content, func_name)
    
    def _replace_function_in_file(self, file_content: str, func_name: str, 
                                    new_code: str) -> Optional[str]:
        """v3.3: Replace function by name — delegates to code_applier module."""
        return code_applier.replace_function_in_file(file_content, func_name, new_code)
    
    def _structural_integrity_check(self, original_file: str, simulated_file: str, 
                                      target_file: str) -> Dict[str, Any]:
        """v3.1: Structural Integrity Gate — delegates to code_validator module."""
        return code_validator.structural_integrity_check(original_file, simulated_file, target_file)
    
    async def _run_canary(self, proposal: EvolutionProposal) -> Dict[str, Any]:
        """Run canary test for a proposal.
        
        v4.0: Enhanced with 6-Phase validation pipeline.
        - Phase -2: Core Interface Lock
        - Phase -1: AST Emission Guard (snippet-level)
        - Phase 0: Policy Gate (pattern matching)
        - Phase 1: Indentation auto-fix
        - Phase 2: Syntax validation (compile on full file)
        - Phase 3: AST Structural Integrity Gate (full file)
        - Phase 4: Runtime Import Test
        """
        try:
            # For config proposals, just validate the format
            if proposal.proposal_type == ProposalType.CONFIG:
                return {"success": True, "message": "Config format validated"}
            
            # For agent proposals, validate the generated code
            if proposal.proposal_type == ProposalType.AGENT:
                return await self._canary_agent_proposal(proposal)
            
            # For CODE proposals: in-memory syntax + structural validation
            if proposal.proposal_type == ProposalType.CODE:
                metadata = getattr(proposal, 'metadata', None)
                if not metadata:
                    return {"success": True, "message": "No metadata — skipping canary (will validate at apply)"}

                # v14: Resolve relative target paths (Brain may return "shared/foo.py")
                _src_root_canary = str(Path(__file__).resolve().parents[2])
                target_file = proposal.targets[0] if proposal.targets else None
                if target_file and not os.path.isabs(target_file):
                    target_file = os.path.join(_src_root_canary, target_file)

                original_code = metadata.get("original_code", "")
                refactored_code = metadata.get("refactored_code", "")

                if not target_file or not original_code or not refactored_code:
                    return {"success": True, "message": "Incomplete metadata — deferred to apply phase"}
                
                # === Phase -2: Core Interface Lock ===
                core_lock = self._check_core_interface_lock(proposal)
                if not core_lock["pass"]:
                    logger.warning(f"🔒 CORE LOCK: {core_lock['reason']}")
                    return {"success": False, "error": core_lock["reason"]}
                
                # === Phase -1: AST Emission Guard (snippet-level) ===
                emission = self._ast_emission_guard(original_code, refactored_code, metadata)
                if not emission["pass"]:
                    logger.error(f"🛡️ AST EMISSION GUARD: {emission['reason']}")
                    return {"success": False, "error": emission["reason"]}
                
                # Read the actual file
                if not os.path.exists(target_file):
                    return {"success": False, "error": f"Target file not found: {target_file}"}
                
                with open(target_file, 'r', encoding='utf-8') as f:
                    file_content = f.read()
                
                # === Phase 0: Policy Gate ===
                policy = self._refactor_policy_check(refactored_code, target_file, metadata)
                if not policy["pass"]:
                    logger.error(f"❌ POLICY GATE BLOCKED: {policy['reason']}")
                    
                    # v3.4: Teach NeuronFabric from policy violation
                    if self._neuron_bridge:
                        self._neuron_bridge.learn_from_policy_block(
                            proposal.proposal_id if hasattr(proposal, 'proposal_id') else "unknown",
                            policy.get("violations", [policy.get("reason", "")]),
                            target_file or "unknown"
                        )
                    
                    return {"success": False, "error": f"Policy violation: {policy['reason']}"}
                
                # Check original code exists (with AST fallback)
                use_ast_replace = False
                func_name = metadata.get("function", "")
                
                if original_code.strip() not in file_content:
                    # String match failed — try AST function lookup
                    if func_name:
                        existing_func = self._find_function_in_file(file_content, func_name)
                        if existing_func:
                            logger.info(f"🔄 AST fallback: found '{func_name}' by name (string match failed)")
                            original_code = existing_func
                            metadata["original_code"] = existing_func
                            use_ast_replace = True
                        else:
                            return {"success": False, "error": f"Function '{func_name}' not found in target (AST lookup failed)"}
                    else:
                        return {"success": False, "error": "Original code not found and no function name for AST fallback"}
                
                # === Phase 1: Auto-fix indentation ===
                orig_indent = self._detect_indent(original_code)
                refac_indent = self._detect_indent(refactored_code)
                
                if orig_indent != refac_indent and orig_indent > 0:
                    logger.info(f"🔧 Auto-fixing indentation: {refac_indent} → {orig_indent} spaces")
                    refactored_code = self._reindent(refactored_code, orig_indent)
                    # Update metadata so apply phase uses the fixed version
                    metadata["refactored_code"] = refactored_code
                
                # Simulate the change in-memory
                if use_ast_replace and func_name:
                    simulated = self._replace_function_in_file(file_content, func_name, refactored_code.strip())
                    if simulated is None:
                        return {"success": False, "error": f"AST replacement failed for '{func_name}'"}
                else:
                    simulated = file_content.replace(original_code.strip(), refactored_code.strip(), 1)
                
                # === Phase 2: Syntax check ===
                try:
                    compile(simulated, target_file, 'exec')
                except SyntaxError as se:
                    logger.error(f"❌ CANARY SYNTAX ERROR: {se}")
                    logger.error(f"❌ Refactored code ({len(refactored_code)} chars): {refactored_code[:300]}")
                    return {"success": False, "error": f"Syntax error in simulated change: {se}"}
                
                # === Phase 3: Structural Integrity Gate (AST) ===
                integrity = self._structural_integrity_check(file_content, simulated, target_file)
                if not integrity["pass"]:
                    logger.error(f"❌ STRUCTURAL INTEGRITY BREACH: {integrity['reason']}")
                    return {"success": False, "error": f"Structural integrity failed: {integrity['reason']}"}
                
                logger.warning(f"✅ CANARY PASS: {os.path.basename(target_file)} — syntax OK, structure OK, {len(refactored_code)} chars")
                
                # === Phase 4: In-Memory Runtime Test ===
                # v4.1: exec() in-memory instead of writing to disk (crash-safe)
                try:
                    import types
                    src_root = str(Path(__file__).resolve().parents[2])
                    if target_file.startswith(src_root) and target_file.endswith('.py'):
                        rel_path = os.path.relpath(target_file, src_root)
                        module_name = rel_path.replace('/', '.').replace('.py', '')
                        
                        # Create an isolated module and exec the simulated code
                        mod = types.ModuleType(module_name)
                        mod.__file__ = target_file
                        try:
                            code_obj = compile(simulated, target_file, 'exec')
                            exec(code_obj, mod.__dict__)
                            logger.info(f"✅ Phase 4 PASS: {module_name} in-memory exec OK")
                        except Exception as exec_err:
                            logger.error(f"❌ Phase 4 RUNTIME FAIL: {module_name} — {exec_err}")
                            return {"success": False, "error": f"Runtime exec failed: {exec_err}"}
                except Exception as phase4_err:
                    # Phase 4 is best-effort — don't block on errors
                    logger.debug(f"Phase 4 skipped: {phase4_err}")
                
                return {"success": True, "message": f"4-Phase validated: {os.path.basename(target_file)}"}
            
            # For other types, run in sandbox (legacy)
            result = await self.sandbox.execute_in_sandbox(
                proposal.proposal_id,
                proposal.diff,
                timeout=config.SANDBOX_TIMEOUT
            )
            
            return {
                "success": result.success,
                "message": result.output,
                "error": result.error,
                "duration_ms": result.duration_ms
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    async def _apply_config_change(self, proposal: EvolutionProposal) -> Dict[str, Any]:
        """Apply a config change to production - ACTUALLY WRITES THE FILE."""
        try:
            import yaml
            
            # Parse the diff to extract values
            # Format: "- current: X\n+ suggested: Y"
            lines = proposal.diff.strip().split('\n')
            old_value = None
            new_value = None
            config_key = None
            
            for line in lines:
                # Extract the config key from comment
                if line.startswith('# ') and 'Adjustment' in line:
                    parts = line.replace('#', '').strip().split(':')
                    if len(parts) > 1:
                        config_key = parts[1].strip()
                    else:
                        config_key = line.replace('#', '').replace('Adjustment', '').strip()
                        
                if line.startswith('- '):
                    # Extract old value
                    if ':' in line:
                        old_value = line.split(':')[-1].strip()
                elif line.startswith('+ '):
                    # Extract new value
                    if ':' in line:
                        new_value = line.split(':')[-1].strip()
            
            if new_value is None:
                return {"success": False, "error": "Could not parse new value from diff"}
            
            # Get the target file path
            target_path = proposal.targets[0] if proposal.targets else None
            if not target_path:
                return {"success": False, "error": "No target path specified"}
            
            # Resolve full path
            if not target_path.startswith('/'):
                # Relative path - use project root
                base_dir = Path(config.PROJECT_ROOT)
                full_path = base_dir / target_path
            else:
                full_path = Path(target_path)
            
            # Create directory if needed
            full_path.parent.mkdir(parents=True, exist_ok=True)
            
            # Load existing config or create new
            if full_path.exists():
                with open(full_path, 'r') as f:
                    config = yaml.safe_load(f) or {}
            else:
                config = {}
            
            # Determine key name
            key_name = config_key or "interval"
            
            # Convert new_value to appropriate type
            try:
                typed_value = float(new_value)
            except ValueError:
                typed_value = new_value
            
            # Update config
            config[key_name] = typed_value
            config["_last_updated"] = time.time()
            config["_updated_by"] = proposal.proposal_id
            
            # Write config file
            with open(full_path, 'w') as f:
                yaml.dump(config, f, default_flow_style=False, allow_unicode=True)
            
            logger.warning(f"📝 CONFIG WRITTEN: {full_path} -> {key_name}={new_value}")
            
            # Record as successful
            return {
                "success": True,
                "message": f"Config written to {full_path}: {old_value} -> {new_value}",
                "file_written": str(full_path),
                "metrics": {
                    "target": str(full_path),
                    "old_value": old_value,
                    "new_value": new_value,
                    "timestamp": time.time()
                }
            }
            
        except Exception as e:
            logger.error(f"Config change failed: {e}")
            return {"success": False, "error": str(e)}
    
    async def handle_trigger(self, event: TriggerEvent) -> Dict[str, Any]:
        """React to a trigger event — the v3.0 cognitive entry point.
        
        Flow:
        1. Consult EvolutionMemory for strategy recommendation
        2. Run creative dream phase (for non-urgent triggers)
        3. Generate targeted proposals based on trigger context
        4. Process each with consequence-aware pipeline
        5. Record results back to memory (learning)
        """
        self._triggers_handled += 1
        trigger_type = event.trigger_type.value
        logger.info(
            f"🎯 Handling trigger: {trigger_type} [{event.severity.value}] "
            f"(trigger #{self._triggers_handled})"
        )
        
        # Check rate limits
        can_execute, reason = self.ledger.can_execute()
        if not can_execute:
            logger.info(f"Trigger handling skipped: {reason}")
            return {"status": "skipped", "reason": reason, "trigger": trigger_type}
        
        # 0.5 Cognitive Elite - Active Questioning to deepen context
        if self._cognitive_engine:
            try:
                insights = self._cognitive_engine.analyze_trigger({
                    "trigger_type": trigger_type, 
                    "severity": getattr(event.severity, 'value', event.severity), 
                    "description": getattr(event, 'description', '')
                })
                if self._journal and insights.get("questions"):
                    self._journal.record("insight", "Cognitive questioning on trigger", context={"questions": insights["questions"]})
            except Exception as e:
                logger.debug(f"Cognitive Orchestrator questioning failed: {e}")

        # 1. Consult memory: what's worked before for this trigger type?
        recommendation = self.memory.get_recommendation(trigger_type)
        logger.info(f"🧠 Memory recommends: {recommendation['strategy']} ({recommendation['basis']})")
        
        # 2. Dream phase for non-urgent triggers (scheduled, belief contradiction)
        dream_result = None
        if event.trigger_type in (TriggerType.SCHEDULED, TriggerType.BELIEF_CONTRADICTION):
            try:
                dream = await self.dreamer.dream(trigger_context=event.to_dict())
                if dream:
                    dream_result = dream.to_dict()
                    self._dreams_realized += 1
                    logger.info(f"💭 Dream realized: {dream.title}")
                    
                    # Record dream to journal
                    if self._journal:
                        self._journal.record(
                            "discovery",
                            f"Evolution dream: {dream.title} — {dream.description[:100]}",
                            context={"dream": dream_result},
                            confidence=dream.confidence,
                            tags=["evolution", "dream", dream.dream_type]
                        )
            except Exception as e:
                logger.debug(f"Dream phase skipped: {e}")
        
        # 3. Generate targeted proposals
        generated = await self._generate_targeted_proposals(event, recommendation)
        
        # 4. Process all pending proposals (includes newly generated)
        result = await self.process_pending_proposals()
        result["trigger"] = trigger_type
        result["recommendation"] = recommendation
        result["dream"] = dream_result
        result["generated"] = generated
        
        # 5. Persist stats
        await self._persist_evolution_stats(result)
        
        # 6. Export distillation data (Teacher → Student training)
        try:
            from .distillation_collector import get_distillation_collector
            collector = get_distillation_collector()
            export = collector.export_training_data(min_quality=0.6)
            if export.get("exported", 0) > 0:
                logger.info(
                    f"📚 Distillation: {export['exported']} training examples exported "
                    f"({export.get('categories', {})})"
                )
        except Exception as e:
            logger.debug(f"Distillation export skipped: {e}")
        
        # 7. Auto-distillation training (every ~10 cycles, if enough data)
        if self.proposals_processed % 10 == 0 and self.proposals_processed > 0:
            try:
                from train_distilled import auto_distill
                distill_result = await auto_distill(min_new_trajectories=50)
                if distill_result.get("success"):
                    logger.warning(
                        f"🧠📖 AUTO-DISTILLATION COMPLETE: "
                        f"{distill_result['examples']} examples, "
                        f"loss={distill_result.get('metrics', {}).get('train_loss', '?')}"
                    )
                elif not distill_result.get("skipped"):
                    logger.warning(f"Auto-distillation failed: {distill_result}")
            except Exception as e:
                logger.debug(f"Auto-distillation skipped: {e}")
        
        # 8. Auto-prune NeuronFabric (every ~20 cycles)
        if self.proposals_processed % 20 == 5:  # Offset from distillation
            try:
                from prune_neurons import auto_prune_if_needed
                prune_result = auto_prune_if_needed()
                if not prune_result.get("skipped") and prune_result.get("total_pruned", 0) > 0:
                    logger.warning(
                        f"🧹 Auto-pruned NeuronFabric: "
                        f"{prune_result['neurons_before']}→{prune_result['neurons_after']} neurons, "
                        f"{prune_result['synapses_before']}→{prune_result['synapses_after']} synapses"
                    )
            except Exception as e:
                logger.debug(f"Auto-prune skipped: {e}")
        
        logger.info(
            f"🧬 Trigger handled: {trigger_type} → "
            f"generated={generated.get('count', 0)}, "
            f"processed={result.get('processed', 0)}"
        )
        return result
    
    async def _generate_targeted_proposals(self, event: TriggerEvent,
                                           recommendation: Dict) -> Dict[str, Any]:
        """Generate proposals targeted at the trigger's context."""
        generated = {
            "count": 0,
            "proposal_ids": [],
            "brain_refactors": 0
        }

        # For learning innovations → apply autonomous learning proposals
        if event.trigger_type == TriggerType.SCHEDULED and \
           event.context.get("reason") == "learning_innovations_ready":
            try:
                from .innovation_applier import get_innovation_applier
                applier = get_innovation_applier()
                learning_proposals = applier.apply_top_innovations(max_count=3)

                if learning_proposals:
                    # Convert to EvolutionProposals and submit
                    for lp in learning_proposals:
                        proposal = self._create_proposal_from_learning(lp)
                        if proposal:
                            self.ledger.record_proposal(proposal)
                            generated["proposal_ids"].append(proposal.proposal_id)

                    generated["learning_innovations"] = len(learning_proposals)
                    generated["count"] += len(learning_proposals)
                    logger.info(
                        f"📚 Applied {len(learning_proposals)} autonomous learning innovations"
                    )
            except Exception as e:
                logger.error(f"Failed to apply learning innovations: {e}")

        # For error spikes and performance issues → brain refactoring + bug hunting
        if event.trigger_type in (TriggerType.ERROR_SPIKE, TriggerType.PERFORMANCE):
            brain_proposals = await self._request_brain_refactoring()
            generated["brain_refactors"] = len(brain_proposals)
            generated["count"] += len(brain_proposals)
            
            # v5.0: Creative bug hunting for error spikes
            if event.trigger_type == TriggerType.ERROR_SPIKE:
                innovation_result = await self._request_innovation(mode="bug_hunter")
                generated["innovations"] = innovation_result.get("total_succeeded", 0)
                generated["count"] += generated["innovations"]
        
        # For goal failures → legacy metrics check
        if event.trigger_type == TriggerType.GOAL_FAILURE:
            await self._check_legacy_metrics()
        
        # For scheduled → full cycle
        if event.trigger_type == TriggerType.SCHEDULED:
            brain_proposals = await self._request_brain_refactoring()
            generated["brain_refactors"] = len(brain_proposals)
            generated["count"] += len(brain_proposals)
            await self._check_legacy_metrics()
            
            # Agent spawn phase — check for gaps and create new agents
            try:
                agent_proposals = await self._agent_spawn_phase()
                if agent_proposals:
                    generated["agent_spawns"] = len(agent_proposals)
                    generated["count"] += len(agent_proposals)
                    logger.info(f"🏭 Agent spawn: {len(agent_proposals)} proposals")
            except Exception as e:
                logger.warning(f"Agent spawn in trigger: {e}")
            
            # v5.0: Creative innovation cycle (feature discovery, architecture review)
            innovation_result = await self._request_innovation(mode="full")
            generated["innovations"] = innovation_result.get("total_succeeded", 0)
            generated["count"] += generated.get("innovations", 0)
        
        # v5.0: Multi-strategy creative proposals (Performance, ErrorPatterns, Curiosity)
        creative_proposals = await self._request_creative_proposals()
        if creative_proposals:
            generated["creative"] = len(creative_proposals)
            generated["count"] += len(creative_proposals)
        
        return generated

    def _create_proposal_from_learning(self, learning_proposal: Dict) -> Optional[EvolutionProposal]:
        """Convert a learning innovation proposal to an EvolutionProposal."""
        try:
            from .proposer import EvolutionProposal, ProposalType

            # Map learning proposal type to EvolutionProposal type
            type_map = {
                'code': ProposalType.CODE,
                'refactor': ProposalType.CODE,
                'agent': ProposalType.AGENT
            }

            proposal_type = type_map.get(
                learning_proposal.get('type', 'code'),
                ProposalType.CODE
            )

            import time
            import uuid
            
            # Create a synthetic change description to act as the 'diff'
            target_files = learning_proposal.get('target_files', [])
            fake_diff = f"# Learning applied to {', '.join(target_files) if target_files else 'system'}"
            
            proposal_id = f"prop_{int(time.time())}_{uuid.uuid4().hex[:8]}"
            
            # Create proposal
            proposal = EvolutionProposal(
                proposal_id=proposal_id,
                proposal_type=proposal_type,
                description=learning_proposal.get('description', 'Autonomous Learning Application'),
                scope="code" if proposal_type == ProposalType.CODE else "agent",
                targets=target_files,
                diff=fake_diff,
                risk_score=0.3,  # Learning innovations are low risk
                expected_benefit="Applied recorded learning innovation",
                rationale=f"Autonomous learning: {learning_proposal.get('learning_context', {}).get('triggered_by', 'Unknown source')}"
            )

            logger.info(
                f"📚 Created proposal from learning: {learning_proposal.get('title', 'Unknown')} "
                f"(innovation_id={learning_proposal.get('learning_context', {}).get('innovation_id', '?')[:16]}...)"
            )

            # Mark the innovation as applied
            from .innovation_applier import get_innovation_applier
            applier = get_innovation_applier()
            innovation_id = learning_proposal.get('learning_context', {}).get('innovation_id')
            if innovation_id:
                applier.update_innovation_status(innovation_id, 'processing_by_evolution')

            return proposal

        except Exception as e:
            logger.error(f"Failed to create proposal from learning: {e}")
            return None

    async def _record_consequence(self, proposal: EvolutionProposal, 
                                  result: Dict[str, Any], success: bool):
        """Record evolution action permanently in ConsequenceEngine."""
        if not self._consequence_engine:
            return
        
        try:
            from ..core.consequence import Action, Outcome
            
            action = Action(
                action_type="evolution_change",
                parameters={
                    "proposal_id": proposal.proposal_id,
                    "type": str(proposal.proposal_type),
                    "target": proposal.targets[0] if proposal.targets else "unknown",
                    "description": proposal.description[:100],
                    "risk_score": proposal.risk_score
                }
            )
            
            outcome = Outcome(
                success=success,
                result=result.get("metrics", {}),
                error=result.get("error") if not success else None
            )
            
            self._consequence_engine.commit(action, outcome)
            logger.debug(f"⚖️ Consequence recorded: {proposal.proposal_id} ({'✅' if success else '❌'})")
            
        except Exception as e:
            logger.debug(f"Consequence recording skipped: {e}")
    
    async def run_evolution_cycle(self):
        """Run a complete evolution processing cycle (legacy + cognitive)."""
        logger.info("🧬 Starting evolution cycle (v3.0 cognitive mode)...")
        
        # Check rate limits
        can_execute, reason = self.ledger.can_execute()
        if not can_execute:
            logger.info(f"Evolution cycle skipped: {reason}")
            return {"status": "skipped", "reason": reason}
        
        # PHASE 1: Project-level analysis
        generated = {
            "count": 0,
            "proposal_ids": [],
            "health_score": 100,
            "improvement_areas": 0
        }
        
        # PHASE 2: Dream phase (creative) — v3.0
        try:
            dream = await self.dreamer.dream()
            if dream:
                generated["dream"] = dream.title
                self._dreams_realized += 1
        except Exception as e:
            logger.debug(f"Dream phase skipped: {e}")
        
        # PHASE 2.5: Brain-assisted refactoring for critical code issues
        brain_proposals = await self._request_brain_refactoring()
        generated["brain_refactors"] = len(brain_proposals)
        
        # PHASE 2.7: Innovation Engine — creative feature generation
        try:
            from .innovation_engine import get_innovation_engine
            innovator = get_innovation_engine()
            innovation_result = await innovator.run_innovation_cycle(max_innovations=1)
            generated["innovations"] = innovation_result.get("total_succeeded", 0)
            if innovation_result.get("innovations"):
                logger.info(f"💡 [PHASE 2.7] Innovation generated: {innovation_result['innovations'][0].get('title', '?')}")
        except Exception as e:
            logger.debug(f"Innovation phase skipped: {e}")
            generated["innovations"] = 0
        
        # PHASE 2.9: Agent Spawning — create new agents from identified needs
        try:
            agent_proposals = await self._agent_spawn_phase()
            generated["agent_spawns"] = len(agent_proposals)
            if agent_proposals:
                logger.info(f"🏭 [PHASE 2.9] Agent proposals: {len(agent_proposals)}")
        except Exception as e:
            logger.warning(f"Agent spawn phase error: {e}")
            generated["agent_spawns"] = 0
        
        # Also check legacy metrics (goal audit)
        await self._check_legacy_metrics()
        
        # PHASE 3: Process pending proposals
        logger.info("⚙️ [PHASE 3] Processing pending proposals...")
        result = await self.process_pending_proposals()
        result["generated"] = generated
        
        # Persist stats to database
        await self._persist_evolution_stats(result)
        
        logger.info(f"🧬 Evolution cycle complete: Brain={generated['brain_refactors']}, Innovations={generated.get('innovations', 0)}, Processed={result.get('processed', 0)}")
        return result

    async def run_intelligence_evolution(self):
        """Run a cycle focused on AI and Cognitive development."""
        logger.info("🧠 [UC3] Starting Cognitive Intelligence Evolution Cycle...")
        
        # Check rate limits
        can_exec, reason = self.ledger.can_execute()
        if not can_exec:
            logger.info(f"Evolution cycle skipped: {reason}")
            return
            
        # PHASE 1: Cognitive Reflection - Request Brain to analyze AI components
        try:
            from .brain_refactor import get_brain_refactor
            brain = get_brain_refactor()
            
            # Specifically target cognitive areas
            proposals = await brain.process_critical_issues(max_issues=2, target_area="cognitive")
            
            if proposals:
                logger.warning(f"💡 [COGNITIVE] Brain generated {len(proposals)} intelligence improvements")
            else:
                logger.info("🧠 No critical cognitive issues identified for this cycle")
                
        except Exception as e:
            logger.error(f"Cognitive evolution phase failed: {e}")
            
        # PHASE 2: Standard processing for any pending items
        await self.process_pending_proposals()
        
        logger.info("🧬 Cognitive Evolution Cycle Complete")
    
    async def _request_brain_refactoring(self) -> List:
        """Request code refactoring from Brain for critical issues."""
        try:
            from .brain_refactor import get_brain_refactor
            brain = get_brain_refactor()
            
            # Process up to 2 critical issues per cycle
            proposals = await brain.process_critical_issues(max_issues=2)
            
            if proposals:
                logger.info(f"🧠 [PHASE 2.5] Brain generated {len(proposals)} refactoring proposals")
            
            return proposals
        except Exception as e:
            logger.debug(f"Brain refactoring skipped: {e}")
            return []
    
    async def _request_innovation(self, mode: str = "full") -> Dict[str, Any]:
        """Request creative innovations from InnovationEngine.
        
        v5.0: Wires the existing InnovationEngine into the trigger flow.
        
        Args:
            mode: "full" for all innovation types, "bug_hunter" for targeted bug hunting
        """
        try:
            from .innovation_engine import get_innovation_engine
            engine = get_innovation_engine()
            
            if mode == "bug_hunter":
                # Targeted: only hunt bugs during error spikes
                innovation = await engine.hunt_bugs()
                result = {
                    "total_attempted": 1,
                    "total_succeeded": 1 if innovation else 0,
                    "innovations": [innovation.to_dict()] if innovation else [],
                    "mode": "bug_hunter"
                }
                if innovation:
                    logger.info(f"🐛 Innovation bug hunt found: {innovation.title}")
            else:
                # Full creative cycle
                result = await engine.run_innovation_cycle(max_innovations=1)
                result["mode"] = "full"
                if result.get("total_succeeded", 0) > 0:
                    logger.info(
                        f"💡 Innovation cycle: {result['total_succeeded']} ideas generated"
                    )
            
            return result
        except Exception as e:
            logger.debug(f"Innovation engine skipped: {e}")
            return {"total_attempted": 0, "total_succeeded": 0, "mode": mode}
    
    async def _request_creative_proposals(self) -> List:
        """Request multi-strategy proposals from CreativeEvolutionAgent.
        
        v5.0: Generates proposals from Performance, ErrorPattern, and
        Curiosity strategies, then records them in the ledger.
        """
        try:
            proposals = await self._creative_agent.generate_proposals(max_total=2)
            
            recorded = []
            for sp in proposals:
                evo_proposal = self._creative_agent.convert_to_evolution_proposal(sp)
                if evo_proposal:
                    success, _ = self.ledger.record_proposal(evo_proposal)
                    if success:
                        recorded.append(evo_proposal)
                        logger.info(
                            f"🧠 Creative proposal recorded: [{sp.strategy_name}] {sp.description[:60]}"
                        )
            
            return recorded
        except Exception as e:
            logger.debug(f"Creative proposals skipped: {e}")
            return []
    
    async def _rectify_code_syntax(self, bad_code: str, error_msg: str, target_file: str) -> Optional[str]:
        """Rectifier Agent functionality: Asks Neural Engine to fix SyntaxErrors."""
        logger.warning(f"🔧 Rectifier triggered for syntax error in {os.path.basename(target_file)}")
        client = None
        try:
            from unified_core.neural_bridge import NeuralEngineClient
            
            # Use Teacher model for repairs if available, else local
            teacher_url = os.getenv("NOOGH_TEACHER_URL", os.getenv("NEURAL_ENGINE_URL", "http://localhost:11434"))
            model_name = "qwen2.5-coder:32b" if os.getenv("NOOGH_TEACHER_URL") else "qwen2.5-coder:14b"
            
            client = NeuralEngineClient(base_url=teacher_url, model=model_name)
            
            prompt = (
                f"The following Python code produced a SyntaxError: {error_msg}\n"
                f"File: {target_file}\n\n"
                f"```python\n{bad_code}\n```\n\n"
                f"Please fix the syntax error. Return ONLY the complete, fixed Python code inside a ```python block."
            )
            
            messages = [{"role": "user", "content": prompt}]
            result = await client.complete(messages, max_tokens=2048, timeout=300)
            
            if result.get("success") and result.get("content"):
                content = result["content"]
                # Extract code block
                if "```python" in content:
                    parts = content.split("```python")
                    if len(parts) > 1:
                        code = parts[-1].split("```")[0].strip()
                        return code
                elif "```" in content:
                    parts = content.split("```")
                    if len(parts) >= 3:
                        code = parts[-2].strip()
                        if code.startswith("python"):
                            code = code[6:].strip()
                        return code
                # Fallback if no markdown blocks
                if "def " in content or "class " in content or "import " in content:
                     return content.strip()
            return None
        except Exception as e:
            logger.error(f"Rectifier failed: {e}")
            return None
        finally:
            if client:
                await client.close()

    async def _apply_code_change(self, proposal: EvolutionProposal) -> Dict[str, Any]:
        """Apply a CODE change to production with backup, validation, and auto-rollback.
        
        Flow:
        1. Extract refactored code from proposal metadata
        2. Create backup of target file
        3. Replace the function in target file
        4. Syntax-check the result with compile()
        5. Runtime import test
        6. If any check fails → auto-rollback from backup
        """
        backup_path = None
        target_file = None
        file_content = None
        
        try:
            metadata = getattr(proposal, 'metadata', None)

            # Helper: resolve relative paths against src_root
            _src_root = str(Path(__file__).resolve().parents[2])

            def _resolve_path(p: str) -> str:
                """Convert relative path to absolute using src_root."""
                if p and not os.path.isabs(p):
                    return os.path.join(_src_root, p)
                return p

            # v11: Support creating new files (agents, innovations)
            if metadata and metadata.get("new_file"):
                target_file = proposal.targets[0] if proposal.targets else None
                if not target_file:
                    return {"success": False, "error": "No target file for new_file"}

                # v14: Resolve relative paths to absolute
                target_file = _resolve_path(target_file)

                generated_code = metadata.get("generated_code", "")
                if not generated_code:
                    return {"success": False, "error": "No generated code for new file"}

                os.makedirs(os.path.dirname(target_file), exist_ok=True)
                
                with open(target_file, 'w', encoding='utf-8') as f:
                    f.write(generated_code)
                
                # Syntax check
                try:
                    compile(generated_code, target_file, 'exec')
                except SyntaxError as e:
                    # RECTIFIER HOOK
                    rectified = await self._rectify_code_syntax(generated_code, str(e), target_file)
                    if rectified:
                        logger.info(f"🔧 Rectifier successfully proposed fix for new file in {target_file}")
                        try:
                            compile(rectified, target_file, 'exec')
                            with open(target_file, 'w', encoding='utf-8') as f:
                                f.write(rectified)
                            generated_code = rectified
                        except SyntaxError as re_re:
                            os.remove(target_file)
                            return {"success": False, "error": f"Rectifier failed format validation parsing: {re_re}"}
                    else:
                        os.remove(target_file)
                        return {"success": False, "error": f"Syntax error in new file: {e}"}
                
                new_lines = len(generated_code.splitlines())
                logger.warning(f"📝 NEW FILE CREATED: {target_file} ({new_lines} lines)")
                
                return {
                    "success": True,
                    "message": f"New file created: {target_file}",
                    "file_written": target_file,
                    "metrics": {
                        "target": target_file,
                        "timestamp": time.time(),
                        "new_file": True,
                        "impact_delta": 0.0,
                        "lines_before": 0,
                        "lines_after": new_lines
                    }
                }
            
            # v1.3 Fallback: extract code from diff field if metadata missing
            if not metadata and proposal.diff:
                metadata = self._extract_metadata_from_diff(proposal)
                if metadata:
                    logger.info(f"📋 Extracted metadata from diff for {proposal.proposal_id}")
            
            if not metadata:
                return {"success": False, "error": "No metadata and no parseable diff"}
            
            target_file = proposal.targets[0] if proposal.targets else None
            # v14: Resolve relative path before checking existence
            target_file = _resolve_path(target_file) if target_file else None
            if not target_file or not os.path.exists(target_file):
                return {"success": False, "error": f"Target file not found: {target_file}"}
            
            original_code = metadata.get("original_code", "")
            refactored_code = metadata.get("refactored_code", "")
            
            if not original_code or not refactored_code:
                return {"success": False, "error": "Missing original or refactored code"}
            
            # Read current file
            with open(target_file, 'r', encoding='utf-8') as f:
                file_content = f.read()
            
            # Verify original code exists (with AST fallback)
            use_ast = False
            func_name = metadata.get("function", "")
            
            if original_code.strip() not in file_content:
                if func_name:
                    existing = self._find_function_in_file(file_content, func_name)
                    if existing:
                        logger.info(f"🔄 Apply AST fallback: '{func_name}' found by name")
                        original_code = existing
                        use_ast = True
                    else:
                        return {"success": False, "error": f"Function '{func_name}' not found (AST lookup failed)"}
                else:
                    return {"success": False, "error": "Original code not found and no function name"}
            
            # Policy gate (same checks as canary)
            policy = self._refactor_policy_check(refactored_code, target_file, metadata)
            if not policy["pass"]:
                return {"success": False, "error": f"Policy violation: {policy['reason']}"}
            
            # Create backup
            backup_path = target_file + f".backup.{int(time.time())}"
            with open(backup_path, 'w', encoding='utf-8') as f:
                f.write(file_content)
            
            # Apply the change
            if use_ast and func_name:
                new_content = self._replace_function_in_file(file_content, func_name, refactored_code.strip())
                if new_content is None:
                    return {"success": False, "error": f"AST replacement failed for '{func_name}'"}
            else:
                new_content = file_content.replace(original_code.strip(), refactored_code.strip(), 1)
            
            # Syntax check BEFORE writing
            try:
                compile(new_content, target_file, 'exec')
            except SyntaxError as se:
                logger.warning(f"❌ Syntax error in refactored code. Invoking Rectifier... {se}")
                # RECTIFIER HOOK
                rectified = await self._rectify_code_syntax(new_content, str(se), target_file)
                if rectified:
                    try:
                        compile(rectified, target_file, 'exec')
                        new_content = rectified
                        logger.info(f"🔧 Rectifier successfully fixed syntax error in existing file {os.path.basename(target_file)}")
                    except SyntaxError as re_re:
                        return {"success": False, "error": f"Rectifier failed to fix Syntax error: {re_re}"}
                else:
                    return {"success": False, "error": f"Syntax error: {se}"}
            
            # v9: Measure real impact — line count reduction
            old_lines = len(file_content.splitlines())
            new_lines = len(new_content.splitlines())
            impact_delta = (old_lines - new_lines) / max(old_lines, 1)  # Positive = reduction
            
            # Write the changed file
            with open(target_file, 'w', encoding='utf-8') as f:
                f.write(new_content)
            
            # Runtime import test — verify the module still loads
            try:
                import importlib, sys
                src_root = str(Path(__file__).resolve().parents[2])
                if target_file.startswith(src_root) and target_file.endswith('.py'):
                    rel_path = os.path.relpath(target_file, src_root)
                    module_name = rel_path.replace('/', '.').replace('.py', '')
                    
                    if module_name in sys.modules:
                        del sys.modules[module_name]
                    
                    importlib.import_module(module_name)
                    logger.info(f"✅ Runtime import OK: {module_name}")
            except Exception as import_err:
                # AUTO-ROLLBACK: restore from backup
                logger.error(f"❌ RUNTIME FAIL after apply — AUTO-ROLLBACK: {import_err}")
                with open(target_file, 'w', encoding='utf-8') as f:
                    f.write(file_content)
                return {"success": False, "error": f"Runtime fail (auto-rolled back): {import_err}"}
            
            logger.warning(f"📝 CODE APPLIED: {target_file} (backup: {backup_path})")
            
            return {
                "success": True,
                "message": f"Code applied to {target_file}",
                "file_written": target_file,
                "backup": backup_path,
                "metrics": {
                    "target": target_file,
                    "function": metadata.get("function", "unknown"),
                    "confidence": metadata.get("confidence", 0),
                    "timestamp": time.time(),
                    "impact_delta": impact_delta,
                    "lines_before": old_lines,
                    "lines_after": new_lines
                }
            }
            
        except Exception as e:
            # Emergency rollback if we have backup
            if backup_path and target_file and file_content:
                try:
                    with open(target_file, 'w', encoding='utf-8') as f:
                        f.write(file_content)
                    logger.error(f"🔄 Emergency rollback completed for {target_file}")
                except Exception:
                    pass
            logger.error(f"Code change failed: {e}")
            return {"success": False, "error": str(e)}
    
    def _extract_metadata_from_diff(self, proposal: EvolutionProposal) -> Optional[Dict[str, Any]]:
        """v1.3: Extract metadata from diff — delegates to diff_parser module."""
        if not proposal.diff:
            return None
        result = extract_metadata_from_diff(proposal.diff)
        if not result:
            logger.debug(f"Failed to parse diff for {proposal.proposal_id}")
        return result
    
    async def _persist_evolution_stats(self, cycle_result: Dict[str, Any]):
        """Write evolution cycle summary to shared_memory database."""
        try:
            from ..core.memory_store import UnifiedMemoryStore
            store = UnifiedMemoryStore()
            
            evolution_id = f"cycle_{int(time.time())}"
            context = {
                "proposals_processed": cycle_result.get("processed", 0),
                "brain_refactors": cycle_result.get("generated", {}).get("brain_refactors", 0),
                "proposals_applied": self.proposals_executed,
                "proposals_rejected": self.proposals_rejected,
            }
            
            outcome = f"processed={context['proposals_processed']}, applied={context['proposals_applied']}"
            success = context["proposals_processed"] >= 0  # Cycle completed = success
            
            await store.record_evolution_step(
                evolution_id=evolution_id,
                path="evolution/controller",
                eye="evolution_cycle",
                rationale="Automated evolution cycle stats",
                context=context,
                outcome=outcome,
                success=success
            )
            logger.debug(f"📊 Evolution stats persisted to DB: {evolution_id}")
        except Exception as e:
            logger.debug(f"Evolution stats persistence skipped: {e}")
    
    async def _check_legacy_metrics(self):
        """Legacy metrics check for backward compatibility."""
        try:
            suggestions = self.goal_audit.propose_weight_adjustments()
            for suggestion in suggestions:
                goal_type = suggestion.get("goal_type", "unknown")
                current = suggestion.get("current_weight", 1.0)
                proposed = suggestion.get("proposed_weight", 1.0)
                reason = suggestion.get("reason", "Performance optimization")
                
                proposal = self.proposer.propose_from_analysis(
                    "threshold_optimization",
                    {
                        "threshold_name": f"goal_weight_{goal_type}",
                        "current_value": current,
                        "suggested_value": proposed,
                        "rationale": reason
                    }
                )
                if proposal:
                    self.proposals_generated += 1
        except Exception as e:
            logger.debug(f"Legacy metrics check: {e}")
    
    async def generate_proposals_from_metrics(self) -> Dict[str, Any]:
        """
        Generate evolution proposals based on system metrics.
        
        Analyzes:
        - Goal performance (success rates, ROI)
        - Prediction accuracy
        - System health indicators
        """
        generated = []
        
        try:
            # Get goal audit results
            suggestions = self.goal_audit.propose_weight_adjustments()
            
            for suggestion in suggestions:
                goal_type = suggestion.get("goal_type", "unknown")
                current = suggestion.get("current_weight", 1.0)
                proposed = suggestion.get("proposed_weight", 1.0)
                reason = suggestion.get("reason", "Performance optimization")
                
                # Create proposal for threshold adjustment (weight is a threshold)
                proposal = self.proposer.propose_from_analysis(
                    "threshold_optimization",
                    {
                        "threshold_name": f"goal_weight_{goal_type}",
                        "current_value": current,
                        "suggested_value": proposed,
                        "rationale": reason
                    }
                )
                
                if proposal:
                    generated.append(proposal.proposal_id)
                    self.proposals_generated += 1
                    logger.info(f"🧬 Generated proposal: {proposal.proposal_id} - {proposal.description}")
            
            # Also check prediction accuracy for interval adjustments
            interval_proposal = await self._check_interval_adjustment()
            if interval_proposal:
                generated.append(interval_proposal)
            
        except Exception as e:
            logger.error(f"Error generating proposals: {e}")
        
        return {"count": len(generated), "proposal_ids": generated}
    
    async def _check_interval_adjustment(self) -> Optional[str]:
        """Check if cycle interval should be adjusted based on real performance metrics."""
        try:
            stats = self.ledger.get_stats()
            
            # Need enough data to make meaningful adjustments
            total = stats.get("total_proposals", 0)
            if total < 5:
                return None  # Not enough data
            
            success_rate = stats.get("success_rate", 0)
            failures_24h = stats.get("failures_24h", 0)
            
            # Data-driven adjustment:
            # High success rate → can be more aggressive (shorter interval)
            # High failure rate → slow down (longer interval)
            current_interval = 3.0
            
            if success_rate > 0.8 and failures_24h == 0:
                suggested = max(2.0, current_interval - 0.5)  # Speed up
                rationale = f"High success rate ({success_rate:.0%}), reducing interval"
            elif failures_24h > 0 or success_rate < 0.5:
                suggested = min(5.0, current_interval + 0.5)  # Slow down
                rationale = f"Failures detected ({failures_24h}), increasing interval"
            else:
                return None  # No adjustment needed
            
            if abs(suggested - current_interval) > 0.1:
                proposal = self.proposer.propose_from_analysis(
                    "interval_optimization",
                    {
                        "current_interval": current_interval,
                        "avg_cycle_duration": current_interval,
                        "suggested_interval": round(suggested, 2)
                    }
                )
                
                if proposal:
                    self.proposals_generated += 1
                    logger.info(f"🧬 Generated interval proposal: {proposal.proposal_id} ({rationale})")
                    return proposal.proposal_id
                    
        except Exception as e:
            logger.error(f"Error in interval check: {e}")
        
        return None
    
    def get_stats(self) -> Dict[str, Any]:
        """Get controller statistics (v3.0 enhanced)."""
        return {
            "version": "3.0.0",
            "proposals_processed": self.proposals_processed,
            "proposals_approved": self.proposals_approved,
            "proposals_rejected": self.proposals_rejected,
            "proposals_executed": self.proposals_executed,
            "proposals_generated": self.proposals_generated,
            "triggers_handled": self._triggers_handled,
            "dreams_realized": self._dreams_realized,
            "auto_execute_config": self.auto_execute_config,
            "auto_execute_policy": self.auto_execute_policy,
            "auto_execute_code": self.auto_execute_code,
            "cognitive_connected": {
                "consequence_engine": self._consequence_engine is not None,
                "scar_tissue": self._scar_tissue is not None,
                "world_model": self._world_model is not None,
                "journal": self._journal is not None
            },
            "memory_stats": self.memory.get_stats(),
            "dreamer_stats": self.dreamer.get_stats(),
            "ledger_stats": self.ledger.get_stats()
        }
    
    # ─── Agent Spawning Pipeline ────────────────────────────
    
    async def _agent_spawn_phase(self) -> List:
        """Phase 2.9: Check if new agents should be spawned.
        
        Analyzes the system for capability gaps and proposes new agents
        through the standard evolution pipeline.
        """
        logger.info("🏭 [PHASE 2.9] Agent spawn phase starting...")
        try:
            from .agent_factory import get_agent_factory
            factory = get_agent_factory()
        except Exception as e:
            logger.warning(f"AgentFactory not available: {e}")
            return []
        
        proposals = []
        
        # Check which builtin blueprints haven't been deployed yet
        for bp_id, blueprint in factory.BUILTIN_BLUEPRINTS.items():
            agent_file = factory.agents_dir / f"{blueprint.role}_agent.py"
            
            # Skip if already deployed
            if agent_file.exists():
                continue
            
            # Skip if already proposed in this cycle
            existing = [
                p for p in self.ledger.proposals.values()
                if p.proposal_type == ProposalType.AGENT
                and p.metadata and p.metadata.get("blueprint_id") == bp_id
                and p.status in (ProposalStatus.PENDING, ProposalStatus.PROMOTED)
            ]
            if existing:
                continue
            
            # Create a proposal for this agent
            proposal_id = f"agent_spawn_{int(time.time())}_{bp_id}"
            
            # Generate the code first for validation
            code = factory._generate_code(blueprint)
            
            proposal = EvolutionProposal(
                proposal_id=proposal_id,
                proposal_type=ProposalType.AGENT,
                description=f"[AGENT] Spawn {blueprint.name}: {blueprint.description}",
                scope="code",
                targets=[str(agent_file)],
                diff=f"Create new file: {agent_file.name}",
                risk_score=45,  # Agent creation default risk
                expected_benefit=f"New capabilities: {', '.join(blueprint.capabilities)}",
                rollback_plan=f"Delete {agent_file.name}",
                rationale=blueprint.reason,
                metadata={
                    "blueprint_id": bp_id,
                    "agent_name": blueprint.name,
                    "role": blueprint.role,
                    "capabilities": blueprint.capabilities,
                    "generated_code": code,
                    "risk_level": blueprint.risk_level,
                    "designed_by": "builtin",
                }
            )
            
            self.ledger.record_proposal(proposal)
            proposals.append(proposal)
            self.proposals_generated += 1
            
            logger.warning(
                f"🏭 Agent proposal submitted: {blueprint.name} "
                f"({len(blueprint.capabilities)} caps) → {proposal_id}"
            )
        
        # ─── Phase 2: Brain-designed blueprints ─────────────
        # Ask the Brain to design agents for system gaps
        # Rate limit: max 1 brain-designed agent per evolution cycle
        if len(proposals) == 0:  # Only if no builtin proposals
            try:
                gaps = factory.analyze_system_gaps()
                logger.info(f"🧠 Agent gaps analysis: {len(gaps)} gaps found")
                
                if gaps:
                    # Pick the first gap that hasn't been proposed yet
                    for gap in gaps:
                        role = gap["role"]
                        agent_file = factory.agents_dir / f"{role}_agent.py"
                        
                        # Skip if already deployed
                        if agent_file.exists():
                            continue
                        
                        # Skip if already proposed
                        existing = [
                            p for p in self.ledger.proposals.values()
                            if p.proposal_type == ProposalType.AGENT
                            and p.metadata and p.metadata.get("role") == role
                            and p.status in (ProposalStatus.PENDING, ProposalStatus.PROMOTED)
                        ]
                        if existing:
                            continue
                        
                        # Ask Brain to design it
                        logger.info(f"🧠 Asking Brain to design agent: {role}")
                        blueprint = await factory.design_agent_with_brain(gap)
                        
                        if blueprint is None:
                            logger.info(f"Brain couldn't design {role} — skipping")
                            continue
                        
                        # Generate code from Brain's blueprint
                        code = factory._generate_code(blueprint)
                        
                        # v5.1: Pre-validate code BEFORE creating proposal
                        # This prevents junk proposals (exec/eval) from polluting the ledger
                        validation = factory._validate_agent_code(code, blueprint)
                        if not validation["valid"]:
                            logger.warning(
                                f"🚫 Brain-designed agent REJECTED pre-validation: "
                                f"{blueprint.name} — {validation['violations']}"
                            )
                            # Record failure for future Brain learning
                            failure_file = Path(__file__).parent / "agent_failures.jsonl"
                            try:
                                import json as _json
                                failure_record = {
                                    "timestamp": time.time(),
                                    "agent_name": blueprint.name,
                                    "role": role,
                                    "violations": validation["violations"],
                                    "reason": "Pre-validation rejected"
                                }
                                with open(failure_file, "a") as ff:
                                    ff.write(_json.dumps(failure_record) + "\n")
                            except Exception:
                                pass
                            continue
                        
                        # Create proposal
                        proposal_id = f"agent_brain_{int(time.time())}_{role}"
                        agent_file = factory.agents_dir / f"{role}_agent.py"
                        
                        proposal = EvolutionProposal(
                            proposal_id=proposal_id,
                            proposal_type=ProposalType.AGENT,
                            description=f"[AGENT/BRAIN] Spawn {blueprint.name}: {blueprint.description}",
                            scope="code",
                            targets=[str(agent_file)],
                            diff=f"Create new file: {agent_file.name} (Brain-designed)",
                            risk_score=55,  # Higher risk for Brain-designed
                            expected_benefit=f"New capabilities: {', '.join(blueprint.capabilities)}",
                            rollback_plan=f"Delete {agent_file.name}",
                            rationale=blueprint.reason,
                            metadata={
                                "blueprint_id": blueprint.agent_id,
                                "agent_name": blueprint.name,
                                "role": blueprint.role,
                                "capabilities": blueprint.capabilities,
                                "generated_code": code,
                                "risk_level": blueprint.risk_level,
                                "designed_by": "brain",
                            }
                        )
                        
                        self.ledger.record_proposal(proposal)
                        proposals.append(proposal)
                        self.proposals_generated += 1
                        
                        logger.warning(
                            f"🧠🏭 Brain-designed agent proposal: {blueprint.name} "
                            f"({len(blueprint.capabilities)} caps) → {proposal_id}"
                        )
                        
                        break  # Max 1 brain design per cycle
                        
            except Exception as e:
                logger.info(f"Brain agent design phase skipped: {e}")
        
        return proposals
    
    async def _canary_agent_proposal(self, proposal: EvolutionProposal) -> Dict[str, Any]:
        """Canary test for agent proposals — validate via AST.
        
        Checks:
        1. Syntax (AST parse)
        2. Contract compliance (inherits AgentWorker)
        3. Safety (no eval/exec, restricted imports)
        4. Size limits
        """
        import ast
        
        metadata = proposal.metadata or {}
        code = metadata.get("generated_code", "")
        
        if not code:
            return {"success": False, "error": "No generated code in proposal metadata"}
        
        violations = []
        
        # 1. Syntax check
        try:
            tree = ast.parse(code)
        except SyntaxError as e:
            return {"success": False, "error": f"Agent syntax error: {e}"}
        
        # 2. Contract: must inherit AgentWorker
        has_agent_class = False
        for node in ast.walk(tree):
            if isinstance(node, ast.ClassDef):
                for base in node.bases:
                    if isinstance(base, ast.Name) and base.id == "AgentWorker":
                        has_agent_class = True
                    elif isinstance(base, ast.Attribute) and base.attr == "AgentWorker":
                        has_agent_class = True
        
        if not has_agent_class:
            violations.append("No class inheriting AgentWorker")
        
        # 3. Safety: no eval/exec (skip for built-in agents — human-curated)
        is_builtin = metadata.get("designed_by") == "builtin"
        if not is_builtin:
            for node in ast.walk(tree):
                if isinstance(node, ast.Call):
                    if isinstance(node.func, ast.Name):
                        if node.func.id in ("eval", "exec", "__import__"):
                            violations.append(f"Dangerous call: {node.func.id}()")
        
        # 4. Safety: banned imports for SAFE agents
        risk_level = metadata.get("risk_level", "SAFE")
        if risk_level == "SAFE":
            banned = {"subprocess", "shutil", "ctypes", "socket", "os.system"}
            for node in ast.walk(tree):
                if isinstance(node, ast.Import):
                    for alias in node.names:
                        if alias.name.split(".")[0] in banned:
                            violations.append(f"Banned import: {alias.name}")
                elif isinstance(node, ast.ImportFrom) and node.module:
                    if node.module.split(".")[0] in banned:
                        violations.append(f"Banned import: {node.module}")
        
        # 5. Size check
        line_count = len(code.splitlines())
        if line_count > 500:
            violations.append(f"Too large: {line_count} lines")
        
        if violations:
            return {
                "success": False,
                "error": f"Agent validation failed: {'; '.join(violations)}",
                "violations": violations
            }
        
        # All validation checks passed — deployment happens in Step 5
        return {
            "success": True, 
            "message": f"Agent validated ({line_count} lines, {risk_level} risk)",
            "line_count": line_count,
            "risk_level": risk_level
        }
    
    async def _apply_agent_proposal(self, proposal: EvolutionProposal) -> Dict[str, Any]:
        """Deploy a validated agent to the agents/ directory."""
        metadata = proposal.metadata or {}
        code = metadata.get("generated_code", "")
        
        if not code:
            return {"success": False, "error": "No code to deploy"}
        
        target = proposal.targets[0] if proposal.targets else None
        if not target:
            return {"success": False, "error": "No target file specified"}
        
        try:
            # Write the agent file
            from pathlib import Path
            target_path = Path(target)
            target_path.parent.mkdir(parents=True, exist_ok=True)
            
            with open(target_path, 'w', encoding='utf-8') as f:
                f.write(code)
            
            # Update agent registry (deduplicate by role)
            try:
                from .agent_factory import get_agent_factory
                factory = get_agent_factory()
                role = metadata.get("role", "unknown")
                entry = {
                    "agent_id": metadata.get("blueprint_id", "unknown"),
                    "name": metadata.get("agent_name", "Unknown"),
                    "role": role,
                    "file": str(target_path),
                    "capabilities": metadata.get("capabilities", []),
                    "reason": proposal.rationale,
                    "created_at": time.time(),
                    "proposal_id": proposal.proposal_id,
                    "deployed_via": "evolution_pipeline"
                }
                # Remove existing entries with same role (prevent duplicates)
                factory._generated_agents = [
                    a for a in factory._generated_agents
                    if a.get("role") != role
                ]
                factory._generated_agents.append(entry)
                factory._save_registry()
            except Exception as e:
                logger.warning(f"Registry update failed (non-fatal): {e}")
            
            logger.warning(
                f"🏭 AGENT DEPLOYED: {metadata.get('agent_name', '?')} → {target_path.name}"
            )
            
            return {
                "success": True,
                "file": str(target_path),
                "agent_name": metadata.get("agent_name"),
                "capabilities": metadata.get("capabilities", [])
            }
            
        except Exception as e:
            logger.error(f"Agent deploy failed: {e}")
            return {"success": False, "error": str(e)}


# Singleton
_controller_instance = None

def get_evolution_controller() -> EvolutionController:
    """Get the global EvolutionController instance."""
    global _controller_instance
    if _controller_instance is None:
        _controller_instance = EvolutionController()
    return _controller_instance
