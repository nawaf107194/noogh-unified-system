            quantity = risk_amount / abs(current_price - stop_loss) if abs(current_price - stop_loss) > 0 else 0

            return {
                'symbol': symbol,
                'signal': final_signal,
                'strength': final_strength,
                'entry_price': current_price,
                'stop_loss': stop_loss,
                'take_profit': take_profits,
